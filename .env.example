# --- Anthropic (co-pilot, categorization) ---
# Get at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional model overrides. Defaults: copilot=Sonnet 4.6, categorize=Haiku 4.5
ANTHROPIC_COPILOT_MODEL=claude-sonnet-4-6
ANTHROPIC_CATEGORIZE_MODEL=claude-haiku-4-5-20251001

# --- OpenAI (Whisper voice input, embeddings for journal semantic search) ---
OPENAI_API_KEY=

# --- Plaid (bank/brokerage sync, Canada) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- Database ---
# Local dev uses SQLite at this path. Leave as-is unless you have a reason.
DATABASE_URL=file:./northstar.db
